implementation

{ Helper: return Handle of a TGObject wrapper, or nil if wrapper is nil }
function ObjH(O: TGObject): gpointer; inline;
begin
  if O = nil then Result := nil else Result := O.Handle;
end;

class function TGtkATContext.TypeID: GType;
begin
  Result := GtkFFI.gtk_at_context_get_type();
end;

function TGtkATContext.GetAccessible: gpointer;
begin
  if Handle = nil then begin Result := nil; Exit; end;
  Result := gpointer(GtkFFI.gtk_at_context_get_accessible(Handle));
end;

function TGtkATContext.GetAccessibleRole: GtkAccessibleRole;
begin
  if Handle = nil then begin Result := GtkAccessibleRole(0); Exit; end;
  Result := GtkAccessibleRole(GtkFFI.gtk_at_context_get_accessible_role(Handle));
end;

class function TGtkWidget.TypeID: GType;
begin
  Result := GtkFFI.gtk_widget_get_type();
end;

procedure TGtkWidget.ActionSetEnabled(const AActionName: string; const AEnabled: Boolean);
begin
  if Handle = nil then Exit;
  GtkFFI.gtk_widget_action_set_enabled(Handle, GLibStr(AActionName), gboolean(AEnabled));
end;

function TGtkWidget.Activate: Boolean;
begin
  Result := (Handle <> nil) and Boolean(GtkFFI.gtk_widget_activate(Handle));
end;

function TGtkWidget.ActivateActionVariant(const AName: string; const AArgs: gpointer): Boolean;
begin
  Result := (Handle <> nil) and Boolean(GtkFFI.gtk_widget_activate_action_variant(Handle, GLibStr(AName), AArgs));
end;

procedure TGtkWidget.ActivateDefault;
begin
  if Handle = nil then Exit;
